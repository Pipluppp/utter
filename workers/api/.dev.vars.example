RATE_LIMIT_TIER2_IP_LIMIT=180
RATE_LIMIT_TIER2_WINDOW_SECONDS=300
RATE_LIMIT_TIER3_IP_LIMIT=300
RATE_LIMIT_TIER3_WINDOW_SECONDS=300

