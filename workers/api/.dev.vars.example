# Core Supabase bindings
SUPABASE_URL=
# Set to Supabase publishable key (legacy name kept for runtime compatibility).
SUPABASE_ANON_KEY=
# Set to Supabase secret/service-role server key (never expose in frontend).
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLIC_URL=

# CORS/origin policy
CORS_ALLOWED_ORIGIN=http://localhost:5173
STORAGE_SIGNING_SECRET=dev-change-me
QUEUE_BILLING_ENABLED=false

# Rate limit tuning (optional)
RATE_LIMIT_WINDOW_SECONDS=300
RATE_LIMIT_TIER1_USER_LIMIT=20
RATE_LIMIT_TIER1_IP_LIMIT=120
RATE_LIMIT_TIER1_WINDOW_SECONDS=300
RATE_LIMIT_TIER2_USER_LIMIT=90
RATE_LIMIT_TIER2_IP_LIMIT=180
RATE_LIMIT_TIER2_WINDOW_SECONDS=300
RATE_LIMIT_TIER3_IP_LIMIT=300
RATE_LIMIT_TIER3_WINDOW_SECONDS=300

# Provider credentials (set as Wrangler secrets for real environments)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com
DASHSCOPE_REGION=intl
QWEN_VC_TARGET_MODEL=qwen3-tts-vc-2026-01-22
QWEN_VD_TARGET_MODEL=qwen3-tts-vd-2026-01-26
VOICE_DESIGN_ENABLED=false
QWEN_ASR_MODEL=qwen3-asr-flash-2026-02-10
QWEN_ASR_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
TRANSCRIPTION_ENABLED=true

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PACK_30K=
STRIPE_PRICE_PACK_120K=
