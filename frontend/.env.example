## Cloudflare Turnstile site key (public).
# Test key below always passes - use a real key for production.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

## Mock mode: skip real API calls for clone/generate/design.
## Set to "true" to use simulated responses with realistic timing.
# VITE_MOCK_CLONE=true

## API backend proxy target used by Vite `/api` proxy.
# Local default runtime is the Cloudflare API Worker on port 8787.
BACKEND_ORIGIN=http://127.0.0.1:8787
