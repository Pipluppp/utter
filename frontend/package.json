{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tunnel": "vite --mode tunnel",
    "tunnel": "cloudflared tunnel --url http://localhost:5173",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --config .oxlintrc.json ./src",
    "lint:fix": "oxlint --config .oxlintrc.json --fix ./src",
    "format": "oxfmt --config .oxfmtrc.jsonc --write ./src !src/routeTree.gen.ts",
    "format:check": "oxfmt --config .oxfmtrc.jsonc --check ./src !src/routeTree.gen.ts",
    "check": "npm run format:check && npm run lint",
    "check:write": "npm run format && npm run lint:fix",
    "test": "vitest --run",
    "ci": "npm run check"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.4.2",
    "@tanstack/react-router": "^1.168.7",
    "@tanstack/router-zod-adapter": "^1.81.5",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-aria-components": "^1.16.0",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss-animate": "^1.0.7",
    "wavesurfer.js": "^7.12.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "^1.167.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "fast-check": "^4.6.0",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "react-grab": "^0.1.29",
    "tailwindcss": "^4.2.2",
    "tailwindcss-react-aria-components": "^2.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.1"
  }
}
