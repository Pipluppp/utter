{
  "private": true,
  "name": "utter",
  "scripts": {
    "sb:start": "supabase start",
    "sb:stop": "supabase stop",
    "sb:reset": "supabase db reset",
    "sb:serve": "supabase functions serve api --env-file ./supabase/.env.local --no-verify-jwt",
    "sb:serve:test": "supabase functions serve api --env-file ./supabase/.env.test --no-verify-jwt",
    "sb:status": "supabase status",
    "cf:bootstrap:wsl": "bash ./scripts/cloudflare-migration/bootstrap-auth.sh",
    "cf:pages:build": "npm --prefix frontend run build",
    "cf:worker:install": "npm --prefix workers/api install",
    "cf:worker:dev": "npm --prefix workers/api run dev",
    "cf:worker:check": "npm --prefix workers/api run check",
    "cf:worker:types": "npm --prefix workers/api run types",
    "test:edge:baseline": "cd supabase/functions/tests && deno test --allow-net --allow-env --allow-read .",
    "test:worker:local": "cd supabase/functions/tests && API_URL=http://127.0.0.1:8787/api deno test --allow-net --allow-env --allow-read .",
    "test:db": "supabase test db",
    "test:edge": "cd supabase/functions/tests && deno test --allow-net --allow-env --allow-read .",
    "test:all": "npm run test:db && npm run test:edge"
  },
  "devDependencies": {
    "supabase": "2.76.12"
  }
}
